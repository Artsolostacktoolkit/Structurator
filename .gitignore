[Nn]Crunch_*
.*crunch*.local.xml

# MightyMoose
*.mm.*
[Mm]ighty[Mm]oose

# AutoReSharper
_ReSharper*/
*.[Rr]e[Ss]harper

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
